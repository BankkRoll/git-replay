{
  "name": "git-replay",
  "version": "0.1.2",
  "description": "A deterministic bug-fixing harness: hand it a bug, get back a reproducing test, a verified fix, and the commit that introduced it — proven by code that runs, not by prose.",
  "type": "module",
  "license": "MIT",
  "author": "BankkRoll",
  "homepage": "https://github.com/BankkRoll/git-replay#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/BankkRoll/git-replay.git"
  },
  "bugs": {
    "url": "https://github.com/BankkRoll/git-replay/issues"
  },
  "keywords": [
    "bug",
    "repro",
    "bisect",
    "git",
    "ai-agent",
    "testing",
    "regression",
    "vercel-ai-gateway",
    "claude",
    "codex"
  ],
  "bin": {
    "replay": "dist/cli/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx src/cli/index.ts",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "test": "vitest run",
    "prepublishOnly": "pnpm build"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.3.179",
    "@anthropic-ai/sdk": "^0.104.1",
    "@openai/codex-sdk": "^0.140.0",
    "execa": "^9.5.1",
    "picocolors": "^1.1.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.9.2",
    "eslint": "^10.4.1",
    "tsx": "^4.19.2",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.18.0",
    "vite": "^6.0.0",
    "vitest": "^4.1.8"
  },
  "packageManager": "pnpm@10.6.5"
}
